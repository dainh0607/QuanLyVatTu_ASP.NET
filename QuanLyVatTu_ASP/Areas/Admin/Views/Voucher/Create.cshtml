@model QuanLyVatTu_ASP.Areas.Admin.Models.Voucher

@{
    ViewData["Title"] = "Tạo Voucher Mới";
}

@section Styles {
    <link rel="stylesheet" href="~/admin/css/voucher.css" asp-append-version="true" />
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="card shadow-sm voucher-form-card">
            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center">
                <a asp-action="Index" class="btn btn-sm btn-light me-3 text-secondary">
                    <i class="fa-solid fa-arrow-left"></i> Trở về
                </a>
                <h5 class="mb-0 text-primary fw-bold">Thiết lập Voucher mới</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" id="voucherForm">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                    <h6 class="text-uppercase text-muted fw-bold mb-3 small"><i class="fa-solid fa-tag me-1"></i> Thông tin cơ bản</h6>
                    
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="MaVoucher" class="form-label fw-medium">Mã Voucher <span class="required-star">*</span></label>
                            <div class="input-group input-group-focus-ring">
                                <span class="input-group-text"><i class="fa-solid fa-barcode"></i></span>
                                <input asp-for="MaVoucher" class="form-control text-uppercase" placeholder="VD: SUMMER2026" />
                            </div>
                            <span asp-validation-for="MaVoucher" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TrangThaiGoc" class="form-label fw-medium">Trạng thái phát hành <span class="required-star">*</span></label>
                            <select asp-for="TrangThaiGoc" class="form-select">
                                <option value="ACTIVE">Hoạt động (ACTIVE)</option>
                                <option value="EXPIRED">Tạm đóng (EXPIRED)</option>
                                <option value="REVOKED">Thu hồi (REVOKED)</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="text-uppercase text-muted fw-bold mb-3 small border-top pt-4"><i class="fa-solid fa-money-bill-wave me-1"></i> Thiết lập giá trị</h6>

                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label asp-for="LoaiGiamGia" class="form-label fw-medium">Loại giảm giá <span class="required-star">*</span></label>
                            <select asp-for="LoaiGiamGia" class="form-select" id="loaiGiamGiaSelect">
                                <option value="PERCENT">Theo phần trăm (%)</option>
                                <option value="FIXED">Số tiền cố định (VNĐ)</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="GiaTriGiam" class="form-label fw-medium">Mức giảm <span class="required-star">*</span></label>
                            <div class="input-group input-group-focus-ring">
                                <input asp-for="GiaTriGiam" class="form-control" type="number" step="0.01" min="0.01" id="giaTriGiamInput" />
                                <span class="input-group-text bg-light text-muted fw-bold" id="loaiGiamGiaAddon">%</span>
                            </div>
                            <span asp-validation-for="GiaTriGiam" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="SoTienGiamToiDa" class="form-label fw-medium">Giảm tối đa</label>
                            <div class="input-group input-group-focus-ring">
                                <input asp-for="SoTienGiamToiDa" class="form-control" type="number" step="1000" id="giamToiDaInput" />
                                <span class="input-group-text bg-light text-muted">đ</span>
                            </div>
                            <small class="text-muted d-block mt-1" style="font-size: 0.75rem;">(Chỉ áp dụng cho theo %)</small>
                            <span asp-validation-for="SoTienGiamToiDa" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <h6 class="text-uppercase text-muted fw-bold mb-3 small border-top pt-4"><i class="fa-solid fa-shield-halved me-1"></i> Điều kiện & Giới hạn</h6>

                    <div class="row g-3 mb-4">
                        <div class="col-md-12 mb-2">
                            <label asp-for="GiaTriDonHangToiThieu" class="form-label fw-medium">Đơn tối thiểu để áp dụng <span class="required-star">*</span></label>
                            <div class="input-group input-group-focus-ring">
                                <span class="input-group-text text-muted">VNĐ</span>
                                <input asp-for="GiaTriDonHangToiThieu" class="form-control" type="number" value="0" step="1000" />
                            </div>
                            <span asp-validation-for="GiaTriDonHangToiThieu" class="text-danger small mt-1"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TongSoLuong" class="form-label fw-medium">Tổng số lượng phát hành <span class="required-star">*</span></label>
                            <div class="input-group input-group-focus-ring">
                                <span class="input-group-text"><i class="fa-solid fa-boxes-stacked"></i></span>
                                <input asp-for="TongSoLuong" class="form-control" type="number" min="1" value="100" />
                            </div>
                            <span asp-validation-for="TongSoLuong" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GioiHanSuDungMoiUser" class="form-label fw-medium">Giới hạn mỗi khách hàng <span class="required-star">*</span></label>
                            <div class="input-group input-group-focus-ring">
                                <span class="input-group-text"><i class="fa-solid fa-user-lock"></i></span>
                                <input asp-for="GioiHanSuDungMoiUser" class="form-control" type="number" min="1" value="1" />
                            </div>
                            <span asp-validation-for="GioiHanSuDungMoiUser" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <h6 class="text-uppercase text-muted fw-bold mb-3 small border-top pt-4"><i class="fa-regular fa-clock me-1"></i> Hiệu lực thời gian</h6>
                    
                    <div class="row g-3 mb-5">
                        <div class="col-md-6">
                            <label asp-for="ThoiGianBatDau" class="form-label fw-medium">Bắt đầu từ <span class="required-star">*</span></label>
                            <input asp-for="ThoiGianBatDau" class="form-control" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="ThoiGianBatDau" class="text-danger small mt-1"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ThoiGianKetThuc" class="form-label fw-medium">Kết thúc lúc <span class="required-star">*</span></label>
                            <input asp-for="ThoiGianKetThuc" class="form-control" type="datetime-local" value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-ddTHH:mm")" />
                            <span asp-validation-for="ThoiGianKetThuc" class="text-danger small mt-1"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end border-top pt-4">
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm">
                            <i class="fa-solid fa-floppy-disk me-2"></i> Lưu Voucher
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function () {
            function updateAddon() {
                var type = $('#loaiGiamGiaSelect').val();
                if (type === 'PERCENT') {
                    $('#loaiGiamGiaAddon').text('%');
                    $('#giaTriGiamInput').attr('max', '100');
                    $('#giamToiDaInput').prop('disabled', false);
                } else {
                    $('#loaiGiamGiaAddon').text('đ');
                    $('#giaTriGiamInput').removeAttr('max');
                    $('#giamToiDaInput').val('');
                    $('#giamToiDaInput').prop('disabled', true);
                }
            }

            $('#loaiGiamGiaSelect').change(updateAddon);
            
            // Auto uppercase coupon code
            $('#MaVoucher').on('input', function() {
                $(this).val($(this).val().toUpperCase().replace(/\s/g, ''));
            });

            // Initialize
            updateAddon();
        });
    </script>
}
