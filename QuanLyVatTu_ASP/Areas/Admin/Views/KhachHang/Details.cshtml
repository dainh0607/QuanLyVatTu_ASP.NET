@model QuanLyVatTu_ASP.Areas.Admin.Models.KhachHang

@{
    ViewData["Title"] = "Chi tiết khách hàng";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Chi tiết khách hàng</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-action="Index">Danh sách khách hàng</a></li>
        <li class="breadcrumb-item active">Chi tiết</li>
    </ol>

    <div class="card mb-4 shadow-sm rounded-4">
         <div class="card-header bg-success text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="fas fa-user-circle me-2"></i>Thông tin: @Model.HoTen</h5>
        </div>
        <div class="card-body">
             <div class="row">
                <div class="col-md-3 text-center mb-3">
                    <label class="form-label fw-bold d-block">Ảnh đại diện</label>
                     @if (!string.IsNullOrEmpty(Model.AnhDaiDien))
                    {
                        <img src="@Model.AnhDaiDien" class="img-fluid rounded-circle shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="@Model.HoTen" />
                    }
                    else
                    {
                         <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto text-secondary fw-bold shadow-sm" style="width: 150px; height: 150px; font-size: 3rem;">
                            @Model.HoTen.Substring(0,1)
                        </div>
                    }
                </div>
                <div class="col-md-9">
                    <div class="row g-3">
                         <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">Mã khách hàng</label>
                            <p class="form-control-plaintext border-bottom">@Model.MaHienThi</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">Họ tên</label>
                            <p class="form-control-plaintext border-bottom fw-bold text-primary">@Model.HoTen</p>
                        </div>
                         <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">Tài khoản</label>
                            <p class="form-control-plaintext border-bottom fw-bold">@Model.TaiKhoan</p>
                        </div>
                         <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">Ngày tạo</label>
                            <p class="form-control-plaintext border-bottom">@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">Email</label>
                             <p class="form-control-plaintext border-bottom">@Model.Email</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">Số điện thoại</label>
                             <p class="form-control-plaintext border-bottom">@Model.SoDienThoai</p>
                        </div>
                         <div class="col-md-4">
                            <label class="form-label fw-bold text-muted">Số nhà / Tên đường</label>
                             <p class="form-control-plaintext border-bottom">@(Model.SoNhaTenDuong ?? "—")</p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-muted">Phường / Xã</label>
                            <p class="form-control-plaintext border-bottom">@(Model.PhuongXa ?? "—")</p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-muted">Tỉnh / Thành phố</label>
                            <p class="form-control-plaintext border-bottom">@(Model.TinhThanhPho ?? "—")</p>
                        </div>

                        <!-- Thông tin thành viên -->
                        <div class="col-12 mt-3">
                            <h6 class="fw-bold text-muted border-bottom pb-2"><i class="fas fa-crown text-warning me-2"></i>Thông tin thành viên</h6>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-muted">Đăng nhập Google</label>
                            <p class="form-control-plaintext border-bottom">
                                @if (Model.DangNhapGoogle)
                                {
                                    <span class="badge bg-info"><i class="bi bi-google me-1"></i>Có</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Không</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-muted">Điểm tích lũy</label>
                            <p class="form-control-plaintext border-bottom fw-bold text-success">@Model.DiemTichLuy.ToString("N0")</p>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold text-muted">Hạng thành viên</label>
                            <p class="form-control-plaintext border-bottom">
                                @if (Model.HangThanhVien != null)
                                {
                                    <span class="badge bg-warning text-dark">@Model.HangThanhVien.TenHang</span>
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có hạng</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">Ngày lên hạng</label>
                            <p class="form-control-plaintext border-bottom">@(Model.NgayLenHang?.ToString("dd/MM/yyyy HH:mm") ?? "—")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted">Ngày hết hạn hạng</label>
                            <p class="form-control-plaintext border-bottom">@(Model.NgayHetHanHang?.ToString("dd/MM/yyyy HH:mm") ?? "—")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light d-flex justify-content-between py-3">
             <a asp-action="Index" class="btn btn-secondary rounded-pill px-4"><i class="fas fa-arrow-left me-2"></i>Quay lại</a>
             <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-primary rounded-pill px-4"><i class="fas fa-edit me-2"></i>Chỉnh sửa</a>
        </div>
    </div>
</div>
