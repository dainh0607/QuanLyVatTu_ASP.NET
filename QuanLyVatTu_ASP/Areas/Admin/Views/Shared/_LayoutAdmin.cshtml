@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin System</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Google+Sans:wght@400;500;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

    <!-- Custom Admin Styles -->
    <link rel="stylesheet" href="~/admin/css/site.css" asp-append-version="true" />

    <!-- Material Variables & Style -->
    <link rel="stylesheet" href="~/admin/css/Shared/_LayoutAdmin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="logo d-flex justify-content-center mb-4">
            <a href="/" class="logo-icon-text d-flex align-items-center gap-2 text-decoration-none">
                <img src="/images/khachhang/Logo.jpg" alt="VatTu Store" style="height: 90px; object-fit: contain; border-radius: 30%;" />
            </a>
        </div>

        @{
            var currentRole = Context.Session.GetString("Role");
        }

        <nav class="admin-nav flex-grow-1">
            @* === Đơn hàng: Quản trị, Nhân viên === *@
            @if (currentRole == "Quản trị" || currentRole == "Nhân viên")
            {
                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DonHang" ? "active" : "")" 
                       asp-area="Admin" asp-controller="DonHang" asp-action="Index">
                        <i class="fa-solid fa-clipboard-list"></i>
                        <span>Đơn hàng</span>
                    </a>
                </div>
            }

            @* === Hóa đơn: Quản trị, Kế toán === *@
            @if (currentRole == "Quản trị" || currentRole == "Kế toán")
            {
                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "HoaDon" ? "active" : "")" 
                       asp-area="Admin" asp-controller="HoaDon" asp-action="Index">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                        <span>Quản lý Hóa đơn</span>
                    </a>
                </div>
            }

            @* === Tích điểm & Voucher: Quản trị, Nhân viên === *@
            @if (currentRole == "Quản trị" || currentRole == "Nhân viên")
            {
                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Voucher" ? "active" : "")" 
                       asp-area="Admin" asp-controller="Voucher" asp-action="Index">
                        <i class="fa-solid fa-ticket"></i>
                        <span>Tích điểm &amp; Voucher</span>
                    </a>
                </div>
            }

            @* === Kho hàng & Vật tư: Quản trị, Thủ kho === *@
            @if (currentRole == "Quản trị" || currentRole == "Thủ kho")
            {
                <div class="nav-item">
                    <a class="nav-link collapsed" href="#collapseQLVT" data-bs-toggle="collapse" role="button" 
                       aria-expanded="@(new[]{"VatTu", "LoaiVatTu", "NhaCungCap"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) ? "true" : "false")">
                        <i class="fa-solid fa-box-open"></i>
                        <span>Kho hàng &amp; Vật tư</span>
                        <i class="fas fa-chevron-down ms-auto small opacity-50"></i>
                    </a>
                    <div class="collapse @(new[]{"VatTu", "LoaiVatTu", "NhaCungCap"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) ? "show" : "")" id="collapseQLVT">
                        <div class="sub-menu">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "VatTu" ? "active" : "")" asp-area="Admin" asp-controller="VatTu" asp-action="Index">Vật tư</a>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "LoaiVatTu" ? "active" : "")" asp-area="Admin" asp-controller="LoaiVatTu" asp-action="Index">Loại vật tư</a>
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NhaCungCap" ? "active" : "")" asp-area="Admin" asp-controller="NhaCungCap" asp-action="Index">Nhà cung cấp</a>
                        </div>
                    </div>
                </div>
            }

            @* === Khách hàng: Quản trị, Nhân viên === *@
            @if (currentRole == "Quản trị" || currentRole == "Nhân viên")
            {
                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "KhachHang" ? "active" : "")"
                       asp-area="Admin" asp-controller="KhachHang" asp-action="Index">
                        <i class="fa-solid fa-users"></i>
                        <span>Khách hàng</span>
                    </a>
                </div>
            }

            @* === Nhân viên: chỉ Quản trị === *@
            @if (currentRole == "Quản trị")
            {
                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NhanVien" ? "active" : "")"
                       asp-area="Admin" asp-controller="NhanVien" asp-action="Index">
                        <i class="fa-solid fa-user-shield"></i>
                        <span>Nhân viên</span>
                    </a>
                </div>
            }

            @* === Xếp hạng & Đánh giá: chỉ Quản trị === *@
            @if (currentRole == "Quản trị")
            {
                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DanhGia" ? "active" : "")"
                       asp-area="Admin" asp-controller="DanhGia" asp-action="Index">
                        <i class="fa-solid fa-comments"></i>
                        <span>Đánh giá &amp; Phản hồi</span>
                    </a>
                </div>
            }

            @* === Thống kê: Quản trị, Kế toán === *@
            @if (currentRole == "Quản trị" || currentRole == "Kế toán")
            {
                <div class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ThongKe" ? "active" : "")"
                       asp-area="Admin" asp-controller="ThongKe" asp-action="Index">
                        <i class="fa-solid fa-chart-pie"></i>
                        <span>Thống kê &amp; Báo cáo</span>
                    </a>
                </div>
            }
        </nav>

        <div class="mt-auto border-top pt-3">
             <a class="nav-link text-danger d-flex align-items-center gap-3 px-3 py-2 rounded-pill hover-bg-light" 
                asp-action="Logout" asp-controller="Account" asp-area="">
                 <i class="fa-solid fa-right-from-bracket"></i>
                 <span>Đăng xuất</span>
             </a>
        </div>
    </aside>

    <!-- CONTENT -->
    <main class="admin-main">
        <header class="admin-header">
            <div class="d-flex align-items-center gap-3">
                <button class="sidebar-toggle text-dark" id="sidebarToggle">
                    <i class="fas fa-bars"></i>
                </button>
                <h1 class="page-title">@ViewData["Title"]</h1>
            </div>

            <div class="d-flex align-items-center gap-3">
                 <a href="/" class="btn btn-outline-secondary rounded-pill btn-sm d-none d-md-block">
                    <i class="fas fa-external-link-alt me-1"></i>Về trang chủ
                 </a>
                 <div class="dropdown">
                    <div class="user-profile" data-bs-toggle="dropdown">
                        <img src="https://ui-avatars.com/api/?name=Admin&background=00639b&color=fff" 
                             class="rounded-circle" width="32" height="32" alt="Admin">
                        <div class="d-none d-sm-block">
                            <span class="d-block small fw-bold">Administrator</span>
                        </div>
                    </div>
                 </div>
            </div>
        </header>

        <div class="content-container">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.20.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        document.getElementById('sidebarToggle').addEventListener('click', function() {
            document.getElementById('adminSidebar').classList.toggle('show');
        });
        
        // Auto-close sidebar on mobile outside click
        document.addEventListener('click', function(e) {
            if (window.innerWidth < 992) {
                const sidebar = document.getElementById('adminSidebar');
                const toggle = document.getElementById('sidebarToggle');
                if (!sidebar.contains(e.target) && !toggle.contains(e.target) && sidebar.classList.contains('show')) {
                    sidebar.classList.remove('show');
                }
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>